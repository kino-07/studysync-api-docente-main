generator client {
  provider = "prisma-client-js"
}

enum Rol {
  ADMIN
  ESTUDIANTE
}

model Usuario {
  id         Int        @id @default(autoincrement())
  nombre     String
  email      String     @unique
  password   String
  rol        Rol        @default(ESTUDIANTE)
  creadoEn   DateTime   @default(now()) @map("creado_en")
  prestamos  Prestamo[]

  @@map("usuarios")
}

model Prestamo {
  id               Int       @id @default(autoincrement())
  libroTitulo      String    @map("libro_titulo")
  libroAutor       String    @default("Desconocido") @map("libro_autor")
  diasPrestamo     Int       @map("dias_prestamo")
  fechaPrestamo    DateTime  @default(now()) @map("fecha_prestamo")
  fechaVencimiento DateTime  @map("fecha_vencimiento")
  devuelto         Boolean   @default(false)
  alertaEnviada    Boolean   @default(false) @map("alerta_enviada")
  creadoEn         DateTime  @default(now()) @map("creado_en")

  estudianteId     Int       @map("estudiante_id")
  estudiante       Usuario   @relation(fields: [estudianteId], references: [id])

  @@map("prestamos")
}